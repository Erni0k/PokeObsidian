{
	"name": "pokemon-collection",
	"version": "1.0.0",
	"description": "Manage a Pokémon TCG collection inside Obsidian using the TCGdex API.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"pokemon",
		"tcg",
		"tcgdex",
		"collection"
	],
	"author": "PokeObsidian",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3"
	},
	"dependencies": {
		"chart.js": "^4.4.1"
	}
}
